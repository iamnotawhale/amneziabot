# ===== App =====
SERVER_PORT=8080
JAVA_OPTS=-Xms256m -Xmx512m

# ===== Xray / Amnezia Docker =====
XRAY_CONTAINER=amnezia-xray
XRAY_CONFIG_PATH=/opt/amnezia/xray/server.json
XRAY_HOST=YOUR_VLESS_IP_OR_DOMAIN
XRAY_PORT=448
XRAY_PUBLIC_KEY=YOUR_XRAY_PUBLIC_KEY
XRAY_SNI=www.example.com
XRAY_SHORT_ID=YOUR_XRAY_SHORT_ID
XRAY_FLOW=xtls-rprx-vision
XRAY_FINGERPRINT=chrome

# ===== Telegram bot =====
# If TELEGRAM_ENABLED=false, BOT_TOKEN and BOT_USERNAME can be empty
# If TELEGRAM_ENABLED=true, BOT_TOKEN and BOT_USERNAME are REQUIRED
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE
TELEGRAM_BOT_USERNAME=PUT_YOUR_BOT_USERNAME_HERE
# How to get:
# 1. Create bot with BotFather (@BotFather on Telegram)
# 2. Get token from BotFather: "123456789:ABCdefGHIjklmnoPQRstuvWXYZabcdefGHi"
# 3. Bot username: "amneziabot" (without @)

# ===== Admin UI/API =====
ADMIN_ENABLED=true
ADMIN_TOKEN=CHANGE_ME_TO_LONG_RANDOM_SECRET
# How to generate: openssl rand -base64 32

# ===== Database =====
# For production use PostgreSQL. Example:
# DB_URL=jdbc:postgresql://127.0.0.1:5432/amneziabot
# DB_USERNAME=amneziabot
# DB_PASSWORD=strong_password
# DB_DRIVER=org.postgresql.Driver

# ===== Jobs =====
APP_EXPIRE_JOB_MS=300000
APP_IDEMPOTENCY_TTL_DAYS=7
APP_IDEMPOTENCY_CLEANUP_MS=3600000
