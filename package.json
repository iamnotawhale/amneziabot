{
  "name": "amneziabot-admin-ui",
  "private": true,
  "version": "0.1.0",
  "description": "TypeScript build for embedded admin UI",
  "scripts": {
    "admin:build": "tsc -p tsconfig.admin.json && cp target/admin-ts/app.js src/main/resources/static/admin/app.js",
    "admin:watch": "concurrently -k -n TSC,COPY \"tsc -p tsconfig.admin.json --watch\" \"node tools/admin-copy-watch.mjs\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  }
}
